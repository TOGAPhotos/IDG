  created_at     DateTime  @default(now()) @db.DateTime(0)
  updated_at     DateTime  @default(now()) @updatedAt @db.DateTime(0)
  reviewed_at    DateTime? @db.DateTime(0)
  is_delete      Boolean   @default(false)

  @@index([status, created_at], map: "idx_aircraft_info_submission_status")
  @@index([create_user, status], map: "idx_aircraft_info_submission_user_status")
  @@index([reg], map: "idx_aircraft_info_submission_reg")
