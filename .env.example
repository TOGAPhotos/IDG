# ============================================
# Ory Hydra + Kratos OAuth2/OIDC 配置
# ============================================

# Ory Hydra 管理端点 (用于后端操作)
ORY_HYDRA_ADMIN_URL="https://auth.togaphotos.com"

# Ory Hydra 公共端点 (用于授权和 token 交换)
ORY_HYDRA_PUBLIC_URL="https://auth.togaphotos.com"

# Ory Kratos 公共端点 (用于用户管理)
ORY_KRATOS_PUBLIC_URL="https://auth.togaphotos.com"

# Ory Kratos Admin API（内网地址，旁路同步用）
ORY_KRATOS_ADMIN_URL="http://localhost:4434"

# auth.togaphotos.com Admin API 密钥（旁路同步创建用户用）
ADMIN_API_KEY=""

# OAuth2 Client 凭据 (在 Hydra 中注册的客户端)
ORY_CLIENT_ID="your-client-id"
ORY_CLIENT_SECRET="your-client-secret"

# OAuth2 回调地址 (必须与 Hydra 中注册的一致)
OAUTH_CALLBACK_URL="http://localhost:3500/api/v2/auth/oauth/callback"

# 前端应用地址 (用于 Web 模式回调跳转)
FRONTEND_URL="https://togaphotos.com"

# Redis 密码 (如果有)
REDIS_DB_PASS=""

# Tencent Cloud CDN 配置
TENCENTCLOUD_SECRET_ID=""
TENCENTCLOUD_SECRET_KEY=""
TENCENTCLOUD_CDN_PKEY=""

# COS CDN 域名
PHOTO_COS_CDN_DOMAIN=""

# Cloudflare Access 日志流保护
# Team domain 形如 https://<team>.cloudflareaccess.com
CF_ACCESS_TEAM_DOMAIN=""
# Zero Trust Access application 的 Application Audience (AUD) Tag
CF_ACCESS_AUD=""
